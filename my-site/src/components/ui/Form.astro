---
const { rounded = false } = Astro.props;
---

  <form class={`bg-gray sm:p-6 h-full w-full lg:max-w-lg ${rounded ? 'rounded-[10px]' : ''}`}
    id="contact-form"
  >

    <div class="mb-4">
      <label for="name" class="block text-black mb-2">Name*</label>
      <input
        type="text"
        id="name"
        name="name"
        placeholder="Name"
        required
        class="w-full px-[30px] py-[18px] border border-black rounded-[14px] text-black outline-none"
      />
    </div>

    <div class="mb-4">
      <label for="email" class="block text-black mb-2">Business Email*</label>
      <input
        type="email"
        id="email"
        name="email"
        placeholder="Business Email"
        required
        class="w-full px-[30px] py-[18px] border border-black rounded-[14px] text-black outline-none"
      />
    </div>

    <div class="mb-4">
      <label for="company-name" class="block text-black mb-2">Company Name*</label>
      <input
        type="text"
        id="company-name"
        name="company-name"
        placeholder="Company Name"
        required
        class="w-full px-[30px] py-[18px] border border-black rounded-[14px] text-black outline-none"
      />
    </div>

    <div class="mb-4">
      <label for="website-url" class="block text-black mb-2">Website URL*</label>
      <input
        type="url"
        id="website-url"
        name="website-url"
        placeholder="https://www.example.com"
        required
        class="w-full px-[30px] py-[18px] border border-black rounded-[14px] text-black outline-none"
      />
    </div>

    <div class="mb-4">
      <label class="block text-black mb-3">E-commerce Platform*</label>
      <div class="space-y-2">
        <div class="flex items-center">
          <input type="radio" id="shopify" name="platform" value="Shopify" required class="w-4 h-4 text-black cursor-pointer" />
          <label for="shopify" class="ml-2 text-black cursor-pointer">Shopify</label>
        </div>
        <div class="flex items-center">
          <input type="radio" id="woocommerce" name="platform" value="WooCommerce" class="w-4 h-4 text-black cursor-pointer" />
          <label for="woocommerce" class="ml-2 text-black cursor-pointer">WooCommerce</label>
        </div>
        <div class="flex items-center">
          <input type="radio" id="platform-other" name="platform" value="Other" class="w-4 h-4 text-black cursor-pointer" />
          <label for="platform-other" class="ml-2 text-black cursor-pointer">Other</label>
        </div>
      </div>
    </div>

    <div class="mb-4">
      <label for="monthly-revenue" class="block text-black mb-2">Monthly Revenue*</label>
      <select
        id="monthly-revenue"
        name="monthly-revenue"
        required
        class="w-full px-[30px] py-[18px] border border-black rounded-[14px] text-black outline-none bg-white"
      >
        <option value="">-- Select range --</option>
        <option value="Under $10,000">Under $10,000</option>
        <option value="$10,000-$50,000">$10,000-$50,000</option>
        <option value="$50,000-$100,000">$50,000-$100,000</option>
        <option value="$100,000-$500,000">$100,000-$500,000</option>
        <option value="$500,000-$1M">$500,000-$1M</option>
        <option value="$1M-$5M">$1M-$5M</option>
        <option value="$5M+">$5M+</option>
      </select>
    </div>

    <div class="mb-4">
      <label for="list-size" class="block text-black mb-2">Email List Size*</label>
      <select
        id="list-size"
        name="list-size"
        required
        class="w-full px-[30px] py-[18px] border border-black rounded-[14px] text-black outline-none bg-white"
      >
        <option value="">-- Select size --</option>
        <option value="Under 1,000">Under 1,000</option>
        <option value="1,000-5,000">1,000-5,000</option>
        <option value="5,000-10,000">5,000-10,000</option>
        <option value="10,000-25,000">10,000-25,000</option>
        <option value="25,000-50,000">25,000-50,000</option>
        <option value="50,000-100,000">50,000-100,000</option>
        <option value="100,000+">100,000+</option>
      </select>
    </div>

    <div class="mb-4">
      <label class="block text-black mb-3">What are your goals?*</label>
      <div class="space-y-2">
        <div class="flex items-center">
          <input type="checkbox" id="revenue" name="goals" value="Increase revenue" class="w-4 h-4 text-black cursor-pointer" />
          <label for="revenue" class="ml-2 text-black cursor-pointer">Increase revenue</label>
        </div>
        <div class="flex items-center">
          <input type="checkbox" id="open-rates" name="goals" value="Improve open rates" class="w-4 h-4 text-black cursor-pointer" />
          <label for="open-rates" class="ml-2 text-black cursor-pointer">Improve open rates</label>
        </div>
        <div class="flex items-center">
          <input type="checkbox" id="automation" name="goals" value="Automation setup" class="w-4 h-4 text-black cursor-pointer" />
          <label for="automation" class="ml-2 text-black cursor-pointer">Automation setup</label>
        </div>
        <div class="flex items-center">
          <input type="checkbox" id="list-growth" name="goals" value="List growth" class="w-4 h-4 text-black cursor-pointer" />
          <label for="list-growth" class="ml-2 text-black cursor-pointer">List growth</label>
        </div>
        <div class="flex items-center">
          <input type="checkbox" id="winback" name="goals" value="Winback campaigns" class="w-4 h-4 text-black cursor-pointer" />
          <label for="winback" class="ml-2 text-black cursor-pointer">Winback campaigns</label>
        </div>
        <div class="flex items-center">
          <input type="checkbox" id="goals-other" name="goals" value="Other" class="w-4 h-4 text-black cursor-pointer" />
          <label for="goals-other" class="ml-2 text-black cursor-pointer">Other</label>
        </div>
      </div>
    </div>

    <div class="mb-4">
      <label for="hear-about" class="block text-black mb-2">How did you hear about us?</label>
      <select
        id="hear-about"
        name="hear-about"
        class="w-full px-[30px] py-[18px] border border-black rounded-[14px] text-black outline-none bg-white"
      >
        <option value="">-- Select an option --</option>
        <option value="Blog">Blog</option>
        <option value="Referral">Referral</option>
        <option value="Social Network">Social Network</option>
        <option value="Google Search">Google Search</option>
        <option value="Other">Other</option>
      </select>
    </div>

    <div class="mb-4">
      <label for="message" class="block text-black mb-2">Message*</label>
      <textarea
        id="message"
        name="message"
        placeholder="Message"
        class="w-full px-[30px] py-[18px] border border-black rounded-[14px] text-black outline-none"
      ></textarea>
    </div>

    <button type="submit" name="submit" class="btn-primary w-full">
      Send
    </button>
    <p id="success-message" class="hidden mt-4 text-green-600">
      Thanks! Your message has been sent.
    </p>
    <p id="error-message" class="hidden mt-4 text-red-600">
    </p>
  </form>
  <script>
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    const successMessage = document.getElementById("success-message");
    const errorMessage = document.getElementById("error-message");

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();

      successMessage?.classList.add("hidden");
      errorMessage?.classList.add("hidden");

      const formData = new FormData(form);

      try {
        const response = await fetch(
          "https://formspree.io/f/xbdenjlk",
          {
            method: "POST",
            body: formData,
            headers: {
              Accept: "application/json",
            },
          }
        );

        const result = await response.json();

        if (response.ok) {
          form.reset();
          successMessage?.classList.remove("hidden");
        } else {
          const resultErrorMessage = result.errors?.map((e) => e.message).join(", ") ||
            "Failed to send message.";
          if (resultErrorMessage === "should be an email") {
            errorMessage.textContent = "Please enter a valid email address.";
          } else {
            errorMessage.textContent = resultErrorMessage;
          }
          errorMessage?.classList.remove("hidden");
        }
      } catch (err) {
        errorMessage.textContent =
          "Network error. Please try again later.";
        errorMessage?.classList.remove("hidden");
      }
    });
  </script>
