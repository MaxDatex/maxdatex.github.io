---
import MainLayout from "../../layouts/MainLayout.astro";
import Tags from "../../components/ui/Tags.astro";
import { getCollection, getEntry } from 'astro:content';
import { formatDate } from "../../utils";

import "../../styles/global.css";

export async function getStaticPaths() {
  const allBlogArticles = await getCollection('blog');
  return allBlogArticles.map((article) => ({
    params: {
      slug: article.slug,
    },
  }));
}

const maybeSlug = Astro.params.slug;
const slug = Array.isArray(maybeSlug) ? maybeSlug[0] : maybeSlug;

if (slug === undefined) {
  throw new Error('Slug is required');
}

const entry = await getEntry('blog', slug);

if(entry === undefined) {
  return Astro.redirect('/404');
}

// In frontmatter, after getting the entry
const allArticles = await getCollection('blog');

const relatedArticles = allArticles
  .filter(a => 
    a.slug !== entry.slug && // not the current post
    a.data.tags.some(tag => entry.data.tags.includes(tag)) // shares a tag
  )
  .slice(0, 6); // show 6

const { Content } = await entry.render();
---

<MainLayout 
  title={entry.data.title}
  description={entry.data.summary}
  image={`/blog/${entry.data.image}`}
  frontmatter={entry.data}
>
	<main class="space-y-40 mb-40 pt-24">
      <section class="bg-white">
          <div class="gap-16 items-center py-8 px-4 mx-auto max-w-screen-xl lg:grid lg:grid-cols-1 lg:py-16 lg:px-3">
              <div class="font-light text-gray-500 sm:text-lg mx-auto max-w-3xl">
                  <a href={`${import.meta.env.BASE_URL}articles`} class="inline-flex items-center font-medium text-black hover:text-green my-4">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="h-6 w-6">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18">
                        </path>
                    </svg>
                    <span class="ml-1 font-bold text-lg">All Articles</span>
                  </a>
                  <h2 class="mb-4 text-4xl tracking-tight font-extrabold text-gray-900">{entry.data.title}</h2>
                  <h3 class="text-lg mb-2">Written by {entry.data.author} on {formatDate(entry.data.pubDate)}</h3>
                  <Tags tags={entry.data.tags} />
                  <img src={'/blog/' + entry.data.image} alt="Article Image" class="w-full h-auto rounded-xl my-6" />
                  <div class="content prose lg:prose-lg">
                    <Content/>
                  </div>

                  {relatedArticles.length > 0 && (
                    <div class="mt-16 pt-8 border-t border-gray-200">
                      <h3 class="text-xl font-bold mb-6">Related Articles</h3>
                      <div class="grid gap-6 md:grid-cols-3">
                        {relatedArticles.map(article => (
                          <a href={`${import.meta.env.BASE_URL}articles/${article.slug}`} 
                            class="btn-forth block p-4 rounded-xl border border-gray-200 hover:border-black transition-colors">
                            <p class="font-semibold text-gray-900 mb-1">{article.data.title}</p>
                            <p class="text-sm text-gray-500 line-clamp-2">{article.data.summary}</p>
                          </a>
                        ))}
                      </div>
                    </div>
                  )}

              </div>
          </div>
      </section>
	</main>
</MainLayout>